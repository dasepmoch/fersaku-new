{
  "name": "fersaku-new",
  "private": true,
  "description": "Fersaku monorepo — frontend (Next.js) + backend (Go)",
  "scripts": {
    "dev": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start": "npm --prefix frontend run start",
    "lint": "npm --prefix frontend run lint",
    "typecheck": "npm --prefix frontend run typecheck",
    "test": "npm --prefix frontend run test",
    "test:run": "npm --prefix frontend run test:run",
    "test:coverage": "npm --prefix frontend run test:coverage",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:api": "npm --prefix frontend run test:e2e:api",
    "test:e2e:api:stack": "bash scripts/e2e-api-stack.sh",
    "verify": "npm --prefix frontend run verify",
    "api:lint": "npm --prefix frontend run api:lint",
    "api:bundle": "npm --prefix frontend run api:bundle",
    "api:generate": "npm --prefix frontend run api:generate",
    "api:check": "npm --prefix frontend run api:check"
  },
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11.12.1 <12"
  }
}
