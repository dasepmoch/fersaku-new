{
  "name": "fersaku-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev NEXT_TEST_WASM=1 next dev --webpack",
    "build": "NEXT_TEST_WASM=1 next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:e2e:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "test:e2e:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:e2e:api:stack": "bash scripts/e2e-api-stack.sh",
    "test:e2e:api": "playwright test -c playwright.api.config.ts",
    "test:e2e:api:ci": "bash scripts/e2e-api-stack.sh && playwright test -c playwright.api.config.ts",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "api:lint": "npx --yes @redocly/cli@1.34.3 lint backend/api/openapi.yaml --config=redocly.yaml",
    "api:bundle": "npx --yes @redocly/cli@1.34.3 bundle backend/api/openapi.yaml -o backend/api/openapi.bundle.yaml",
    "api:generate": "openapi-typescript backend/api/openapi.yaml -o shared/api/generated/openapi.ts --root-types --export-type -c /dev/null",
    "api:check": "openapi-typescript backend/api/openapi.yaml -o shared/api/generated/openapi.ts --root-types --export-type -c /dev/null --check",
    "ci:assert:openapi": "node scripts/ci-assert-suite.mjs openapi-contract",
    "ci:assert:integration": "node scripts/ci-assert-suite.mjs backend-integration",
    "ci:assert:mock-e2e": "node scripts/ci-assert-suite.mjs frontend-mock-e2e && node scripts/ci-assert-suite.mjs qlt-230-visual-a11y",
    "ci:assert:api-e2e": "node scripts/ci-assert-suite.mjs cross-stack-api-e2e && node scripts/ci-assert-suite.mjs qlt-220-api-e2e",
    "ci:assert:security": "node scripts/ci-assert-suite.mjs security-negative && node scripts/ci-assert-suite.mjs qlt-300-security",
    "ci:assert:performance": "node scripts/ci-assert-suite.mjs qlt-310-performance",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run lint -- --max-warnings=0 && npm run typecheck && npm run test:run && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.6",
    "@fontsource/instrument-serif": "^5.2.6",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@next/swc-wasm-nodejs": "16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "openapi-typescript": "^7.9.1",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11.12.1 <12"
  },
  "packageManager": "npm@11.12.1"
}
