# Fersaku backend local env example (BE-002).
# Copy to .env and fill as needed. NEVER commit real secrets.
# Production secrets come from a secret manager, not this file.

# Deployment env only (not payment_mode SANDBOX|LIVE)
APP_ENV=local

# API listen address inside process/container
HTTP_ADDR=:8080

LOG_LEVEL=info
SHUTDOWN_TIMEOUT_SEC=15

# Postgres (BE-100): when set, app opens a real pgx pool; when empty, noop pinger.
# Local compose host port 5433 (container 5432).
DATABASE_URL=postgres://fersaku:fersaku_local@localhost:5433/fersaku?sslmode=disable
REDIS_URL=redis://localhost:6380/0

# Xendit: local/CI must use fake; production forbids fake
XENDIT_MODE=fake
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_ACCOUNT_SCOPE=xendit-primary

# Session / CSRF (local placeholders only — replace in staging/production)
SESSION_COOKIE_NAME=fersaku_session
SESSION_SECRET=local-dev-session-secret-not-for-prod
CSRF_SECRET=local-dev-csrf-secret-not-for-prod

# KYC field encryption (required in production; empty ok for local scaffold)
KYC_ENCRYPTION_KEY=
# Stock/credential encryption (BE-230). Falls back to KYC_ENCRYPTION_KEY when empty.
STOCK_ENCRYPTION_KEY=

# Object storage — local MinIO (S3-compatible path semantics match R2)
R2_ENDPOINT=http://localhost:9000
R2_BUCKET_PUBLIC=fersaku-public
R2_BUCKET_PRIVATE=fersaku-private
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_REGION=auto
R2_FORCE_PATH_STYLE=true

# Mail — local Mailpit (no real provider)
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_FROM=noreply@localhost
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Worker
WORKER_RUN_ONCE=false

# BE-130: attach SUPER_ADMIN on `make seed` when the user already exists.
# Register/verify the email first, then:
#   BOOTSTRAP_ADMIN_EMAIL=admin@example.com make seed
# Migration 000004 seeds system roles/permissions; this only assigns SUPER_ADMIN.
BOOTSTRAP_ADMIN_EMAIL=
