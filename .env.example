# Safe local prototype defaults. Never put secrets in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_DATA_SOURCE=mock
NEXT_PUBLIC_APP_STAGE=prototype
NEXT_PUBLIC_MOCK_SCENARIO=default

# INT-030 browser topology: leave empty for same-origin relative /v1
# (Next rewrites /v1/* → Go API). Do not put internal SSR hosts here.
# DEPRECATED for browser same-origin — only set for temporary cross-origin debug.
# NEXT_PUBLIC_API_URL=

# Server-only (never NEXT_PUBLIC_*): SSR fetch + next.config /v1 rewrites target.
# Local compose default when unset: http://127.0.0.1:18080 (host) → :8080 (container).
# Compose network: http://api:8080
# Required and non-placeholder when NEXT_PUBLIC_APP_STAGE=live.
# API_INTERNAL_URL=http://127.0.0.1:18080

# Optional override for rewrite target only (defaults to API_INTERNAL_URL).
# API_PROXY_TARGET=http://127.0.0.1:18080

# Live / API-connected deployment (same-origin browser; internal SSR URL required):
# NEXT_PUBLIC_DATA_SOURCE=api
# NEXT_PUBLIC_APP_STAGE=live
# API_INTERNAL_URL=http://api:8080
